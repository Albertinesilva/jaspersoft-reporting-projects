	<variable name="A_POSITIVO" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{tipo_sanguineo} != null && $F{tipo_sanguineo}.trim().equalsIgnoreCase("A+") ? 1 : 0]]></variableExpression>
