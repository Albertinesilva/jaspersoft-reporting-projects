	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Postgres Cad-Mototaxista Data Adapter"/>
	<property name="net.sf.jasperreports.print.create.bookmarks" value="false"/>
	<style name="estilo_cores_alternadas" mode="Opaque" backcolor="#FFFFFF">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2==0]]></conditionExpression>
			<style mode="Opaque" backcolor="#CCFFFF"/>
		</conditionalStyle>
	</style>
	<parameter name="LOGO_SINALEIRA" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT
  dados.nome,
  dados.numero_ordem,
  dados.modelo_motocicleta,
  dados.data_nascimento,
  dados.idade,
  CASE
    WHEN dados.idade >= 18 AND dados.idade <= 25 THEN '18 a 25 anos'
    WHEN dados.idade >= 26 AND dados.idade <= 35 THEN '26 a 35 anos'
    WHEN dados.idade >= 36 AND dados.idade <= 45 THEN '36 a 45 anos'
    WHEN dados.idade >= 46 AND dados.idade <= 60 THEN '46 a 60 anos'
    ELSE 'Acima de 60 anos'
  END AS faixa_etaria,
  CASE
    WHEN dados.idade >= 18 AND dados.idade <= 25 THEN 5
    WHEN dados.idade >= 26 AND dados.idade <= 35 THEN 4
    WHEN dados.idade >= 36 AND dados.idade <= 45 THEN 3
    WHEN dados.idade >= 46 AND dados.idade <= 60 THEN 2
    ELSE 1
  END AS ordem_faixa
FROM (
  SELECT
    c.nome,
    c.numero_ordem,
    mm.modelo_moto AS modelo_motocicleta,
    c.data_nascimento,
    EXTRACT(YEAR FROM AGE(CURRENT_DATE, c.data_nascimento)) AS idade
  FROM condutor c
  JOIN motocicleta mc ON mc.id = c.motocicleta_fk
  JOIN moto_modelo mm ON mm.id = mc.moto_modelo_fk
) AS dados
ORDER BY ordem_faixa, dados.nome;]]>
	</queryString>
