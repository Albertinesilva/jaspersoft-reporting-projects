	<detail>
		<band height="30" splitType="Stretch">
			<textField>
				<reportElement style="estilo_cores_alternadas" x="0" y="0" width="58" height="30" uuid="a605d3a7-5190-41e7-951c-50cb0ed091d7">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="f37c2b2d-2fc3-4031-b1e5-8229eb419046"/>
				</reportElement>
				<box padding="3"/>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{numero_ordem}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement style="estilo_cores_alternadas" x="239" y="0" width="118" height="30" uuid="44ee9d42-a611-47f3-bb85-753a515ac396">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="c6e085b9-cabe-4c68-856f-8d8865fb0dfd"/>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{nome_marca}+ " - "+$F{modelo_moto}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement style="estilo_cores_alternadas" x="58" y="0" width="100" height="30" uuid="4abe2c58-b4f1-4e41-844f-70033d0d7bb2">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="45a5dff8-bc3a-4622-9027-e654389c821f"/>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{nome_condutor} != null && $F{nome_condutor}.split(" ").length > 1
  ? $F{nome_condutor}.split(" ")[0] + " " + $F{nome_condutor}.split(" ")[1]
  : ($F{nome_condutor} != null ? $F{nome_condutor} : "")]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement style="estilo_cores_alternadas" x="357" y="0" width="80" height="30" uuid="c1f8d7b5-4f00-4fcf-b466-c4e3a5803e5a">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="10e75e4b-16e9-4efe-a21f-ed97abc80ffb"/>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{placa}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement style="estilo_cores_alternadas" x="158" y="0" width="81" height="30" uuid="2f06528e-a0e3-449a-90e8-598a8c30d422">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="41905b03-1015-4022-aa65-8db7442d673d"/>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{modalidade_condutor} != null  ? $F{modalidade_condutor}.substring(0,1).toUpperCase() + $F{modalidade_condutor}.substring(1).toLowerCase() : ""]]></textFieldExpression>
			</textField>
			<textField pattern="dd/MM/yyyy">
				<reportElement style="estilo_cores_alternadas" x="437" y="0" width="130" height="30" uuid="a41b6cfd-f37e-46d8-b63c-5010f9cff04b">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="9a2119ee-814e-40ce-952e-307c42b60814"/>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{data_vencimento_alvara} != null
? (
    $F{data_vencimento_alvara}.before(new java.sql.Date(System.currentTimeMillis()))
    ? "Venceu há " + 
        java.time.temporal.ChronoUnit.DAYS.between(
          $F{data_vencimento_alvara}.toLocalDate(), 
          java.time.LocalDate.now()
        ) + " dias" : "Faltam " + 
        java.time.temporal.ChronoUnit.DAYS.between(
          java.time.LocalDate.now(),
          $F{data_vencimento_alvara}.toLocalDate()
        ) + " dias para vencer"
  )
: " - "]]></textFieldExpression>
			</textField>
		</band>
	</detail>
