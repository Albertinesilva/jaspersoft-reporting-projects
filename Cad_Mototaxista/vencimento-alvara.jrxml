	</field>
	<variable name="TOTAL_ALVARA_PROXIMO_VENCER" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[($F{data_vencimento_alvara} != null &&
 !$F{data_vencimento_alvara}.before(java.sql.Date.valueOf(java.time.LocalDate.now()))) ? 1 : 0]]></variableExpression>
	</variable>
