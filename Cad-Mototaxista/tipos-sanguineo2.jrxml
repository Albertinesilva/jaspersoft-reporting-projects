 && $V{A_POSITIVO} >= $V{O_NEGATIVO}) ? "A+" :

($V{A_NEGATIVO} >= $V{B_POSITIVO} && $V{A_NEGATIVO} >= $V{B_NEGATIVO} && $V{A_NEGATIVO} >= $V{AB_POSITIVO}
 && $V{A_NEGATIVO} >= $V{AB_NEGATIVO} && $V{A_NEGATIVO} >= $V{O_POSITIVO} && $V{A_NEGATIVO} >= $V{O_NEGATIVO}) ? "A-" :

