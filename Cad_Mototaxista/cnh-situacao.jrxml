		<property name="com.jaspersoft.studio.field.name" value="numero_ordem"/>
		<property name="com.jaspersoft.studio.field.label" value="numero_ordem"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="condutor"/>
	</field>
	<field name="nome" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome"/>
		<property name="com.jaspersoft.studio.field.label" value="nome"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="condutor"/>
	</field>
	<field name="numero_habilitacao" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="numero_habilitacao"/>
		<property name="com.jaspersoft.studio.field.label" value="numero_habilitacao"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="cnh"/>
	</field>
	<field name="data_vencimento" class="java.sql.Date">
		<property name="com.jaspersoft.studio.field.name" value="data_vencimento"/>
		<property name="com.jaspersoft.studio.field.label" value="data_vencimento"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="cnh"/>
	</field>
	<field name="dias_para_vencer_ou_vencida" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.field.name" value="dias_para_vencer_ou_vencida"/>
		<property name="com.jaspersoft.studio.field.label" value="dias_para_vencer_ou_vencida"/>
	</field>
	<field name="descricao_vencimento" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="descricao_vencimento"/>
		<property name="com.jaspersoft.studio.field.label" value="descricao_vencimento"/>
	</field>
	<variable name="TOTAL_VENCIDAS" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[($F{dias_para_vencer_ou_vencida} < 0) ? 1 : 0]]></variableExpression>
	</variable>
	<variable name="VENCEM_APOS_30_DIAS" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[($F{dias_para_vencer_ou_vencida} > 30) ? 1 : 0]]></variableExpression>
	</variable>
	<variable name="VENCEM_PROXIMOS_30_DIAS" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[($F{dias_para_vencer_ou_vencida} >= 0 && $F{dias_para_vencer_ou_vencida} <= 30) ? 1 : 0]]></variableExpression>
	</variable>
