<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="motocicletas-mais-utilizadas" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b31566c8-68c8-4a96-9013-37e00079c881">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Postgres Cad-Mototaxista Data Adapter"/>
	<style name="estilo_cores_alternadas" mode="Opaque" backcolor="#FFFFFF">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2==0]]></conditionExpression>
			<style mode="Opaque" backcolor="#CCFFFF"/>
		</conditionalStyle>
	</style>
	<parameter name="LOGO_SINALEIRA" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT 
    mm.modelo_moto AS nome_modelo,
    m.nome_marca AS nome_marca,
    mm.ativo AS modelo_ativo,
    COUNT(c.id) AS quantidade_com_condutor
FROM moto_modelo mm
JOIN moto_marca m ON mm.marca_fk = m.id
JOIN motocicleta mc ON mc.moto_modelo_fk = mm.id
LEFT JOIN condutor c ON c.motocicleta_fk = mc.id
WHERE c.id IS NOT NULL
GROUP BY mm.modelo_moto, m.nome_marca, mm.ativo
ORDER BY quantidade_com_condutor DESC]]>
	</queryString>
	<field name="nome_modelo" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome_modelo"/>
		<property name="com.jaspersoft.studio.field.label" value="nome_modelo"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="moto_modelo"/>
	</field>
	<field name="nome_marca" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome_marca"/>
		<property name="com.jaspersoft.studio.field.label" value="nome_marca"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="moto_marca"/>
	</field>
	<field name="modelo_ativo" class="java.lang.Boolean">
		<property name="com.jaspersoft.studio.field.name" value="modelo_ativo"/>
		<property name="com.jaspersoft.studio.field.label" value="modelo_ativo"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="moto_modelo"/>
	</field>
	<field name="quantidade_com_condutor" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="quantidade_com_condutor"/>
		<property name="com.jaspersoft.studio.field.label" value="quantidade_com_condutor"/>
	</field>
	<variable name="MAX_QTD_MODELO" class="java.lang.Long" calculation="Highest">
		<variableExpression><![CDATA[$F{quantidade_com_condutor}]]></variableExpression>
	</variable>
	<variable name="MODELO_MAIS_CADASTRADO" class="java.lang.String">
		<variableExpression><![CDATA[$F{quantidade_com_condutor}.longValue() == $V{MAX_QTD_MODELO}.longValue() ? $F{nome_modelo} : $V{MODELO_MAIS_CADASTRADO}]]></variableExpression>
		<initialValueExpression><![CDATA[""]]></initialValueExpression>
	</variable>
	<variable name="MIN_QTD_MODELO" class="java.lang.Long" calculation="Lowest">
		<variableExpression><![CDATA[$F{quantidade_com_condutor}]]></variableExpression>
	</variable>
	<variable name="MODELO_MENOS_CADASTRADO" class="java.lang.String">
		<variableExpression><![CDATA[$F{quantidade_com_condutor}.longValue() == $V{MIN_QTD_MODELO}.longValue() ? $F{nome_modelo} : $V{MODELO_MENOS_CADASTRADO}]]></variableExpression>
		<initialValueExpression><![CDATA[""]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_MOTOCICLETAS_CADASTRADA" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{quantidade_com_condutor}]]></variableExpression>
	</variable>
