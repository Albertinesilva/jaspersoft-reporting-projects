		<property name="com.jaspersoft.studio.field.label" value="data_vencimento_alvara"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="condutor"/>
	</field>
	<field name="placa" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="placa"/>
		<property name="com.jaspersoft.studio.field.label" value="placa"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="motocicleta"/>
	</field>
	<field name="nome_marca" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome_marca"/>
		<property name="com.jaspersoft.studio.field.label" value="nome_marca"/>
