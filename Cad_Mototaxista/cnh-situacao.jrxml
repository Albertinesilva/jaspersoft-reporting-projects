	<parameter name="LOGO_SINALEIRA" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT
  c.numero_ordem,
  c.nome,
  cnh.numero_habilitacao,
  cnh.data_vencimento,
  (cnh.data_vencimento - CURRENT_DATE) AS dias_para_vencer_ou_vencida,
  CASE
    WHEN (cnh.data_vencimento - CURRENT_DATE) < 0 THEN 
      'Está vencida há ' || ABS(cnh.data_vencimento - CURRENT_DATE) || ' dias'
    WHEN (cnh.data_vencimento - CURRENT_DATE) = 0 THEN 
      'Vence hoje'
    ELSE 
      'Falta ' || (cnh.data_vencimento - CURRENT_DATE) || ' dias para vencer'
  END AS descricao_vencimento
FROM condutor c
JOIN cnh ON cnh.id = c.cnh_fk
ORDER BY dias_para_vencer_ou_vencida ASC;]]>
	</queryString>
