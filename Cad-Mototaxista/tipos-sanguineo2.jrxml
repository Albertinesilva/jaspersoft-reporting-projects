	<queryString language="SQL">
		<![CDATA[SELECT 
    c.numero_ordem,
    c.nome,
    ct.telefone_comercial,
    c.data_nascimento,
    c.tipo_sanguineo
FROM 
    condutor c
JOIN 
    contato ct ON c.contato_fk = ct.id
WHERE 
    c.tipo_sanguineo IS NOT NULL
ORDER BY 
    c.tipo_sanguineo ASC,
    c.nome ASC]]>
	</queryString>
