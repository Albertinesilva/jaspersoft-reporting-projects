	<parameter name="LOGO_SINALEIRA" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT 
    c.nome AS nome_condutor,
    c.numero_ordem,
    c.modalidade_condutor,
    c.data_vencimento_alvara,
    m.placa,
    mm.nome_marca,
    mdl.modelo_moto
FROM 
    condutor c
JOIN 
    motocicleta m ON c.motocicleta_fk = m.id
JOIN 
    moto_modelo mdl ON m.moto_modelo_fk = mdl.id
JOIN 
    moto_marca mm ON mdl.marca_fk = mm.id
WHERE 
    c.data_vencimento_alvara IS NOT NULL
ORDER BY 
    c.data_vencimento_alvara ASC]]>
	</queryString>
	<field name="nome_condutor" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome_condutor"/>
		<property name="com.jaspersoft.studio.field.label" value="nome_condutor"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="condutor"/>
	</field>
	<field name="numero_ordem" class="java.lang.String">
