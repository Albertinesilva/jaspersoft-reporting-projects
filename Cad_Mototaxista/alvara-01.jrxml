	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="555" splitType="Stretch">
			<rectangle>
				<reportElement mode="Opaque" x="-20" y="-20" width="842" height="570" backcolor="#D3D3D3" uuid="f8dc15e4-5b18-43fd-add2-58ddf2e52ab9"/>
				<graphicElement>
					<pen lineWidth="6.0" lineColor="#000000"/>
				</graphicElement>
			</rectangle>
			<textField>
				<reportElement x="-14" y="490" width="823" height="54" uuid="a86645c0-b53e-4942-b9a6-1eb3ec730c06"/>
				<textElement textAlignment="Justified" verticalAlignment="Bottom" markup="html">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA["Autorizamos, por meio deste alvará, o Sr. <b>"+$F{nome}+"</b> a desempenhar suas atividades como mototaxista de forma regular e legal. O condutor encontra-se cadastrado sob o número de ordem <b>"+$F{numero_ordem}+"</b>, vinculado à modalidade <b>"+$F{modalidade_condutor}+"</b>, conforme registro nos sistemas da Secretaria Municipal de Trânsito e Transporte de Santo Antônio de Jesus. Para o exercício das suas funções, o condutor utiliza a motocicleta <b>"+$F{nome_marca}+" "+ $F{modelo_moto}+"</b>, de placa <b>"+$F{placa}+"</b>, devidamente vinculada ao cadastro. Este alvará tem validade até o dia <b>"+$F{data_vencimento_alvara}+"</b>, e poderá ser verificado por meio do código QR ou pelo endereço eletrônico: <b>https://pre-cadastro-mototaxista-saj.netlify.app/index.html</b>"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="240" width="802" height="30" uuid="e9776337-69d2-454a-86ca-e220fc196790"/>
				<textElement textAlignment="Center" verticalAlignment="Middle" markup="html">
					<font size="18"/>
				</textElement>
				<textFieldExpression><![CDATA["<b>Condutor: </b>"+$F{nome}+" - <b>Motocicleta: </b>"+$F{nome_marca}+ " "+$F{modelo_moto}+" - <b>Placa:</b> "+$F{placa}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement mode="Opaque" x="49" y="-10" width="761" height="69" backcolor="#D3D3D3" uuid="266a224b-4d60-4a0b-9d02-5ce6745d856b"/>
